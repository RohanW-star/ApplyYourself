  m_EditorClassIdentifier: Assembly-CSharp::DialoogSysteem
  dialogueText: {fileID: 3746096133349129410}
  typingSpeed: 0.01
  sentences:
  - Ik raad aan om materialen te gebruiken die recycled kunnen worden.
  - Hierdoor verminderen we de stress op de aarde voor steeds meer materialen.
  - Ook is het erg goed om materialen te gebruiken die lang mee gaan en die goed
    te repareren zijn.
  opties:
  - {fileID: 318355850402227866}
