  m_Script: {fileID: 11500000, guid: 7ed69b4369b61f54a8fa52440f19a322, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialoogSysteem
  dialogueText: {fileID: 2273437353587009233}
  typingSpeed: 0.01
  sentences:
  - Ik raad aan om gebouwen voornamelijk van hout te maken en het gebruik van beton
    en cement te verminderen.
  - Het maken van beton en cement kost namelijk veel energie en stoot veel broeikasgassen
    uit.
  - Een constructie van hout bespaard dus CO2 en daarnaast kan het gebouw dan ook
    nog dienen als een goede opslagplek voor koolstof.
  opties:
  - {fileID: 3254806847780821963}
