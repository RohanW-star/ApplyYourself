  m_Script: {fileID: 11500000, guid: 7ed69b4369b61f54a8fa52440f19a322, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialoogSysteem
  dialogueText: {fileID: 553016107481959839}
  typingSpeed: 0.01
  sentences:
  - "Ik raad aan om te zorgen dat elk gebouw goed ge\xEFsoleerd is."
  - Dit kan heel erg helpen bij het verminderen van energiegebruik.
  - Isolatie verminderd kou en CO2-uitstoot, waardoor mensen minder energie hoeven
    te gebruiken om hun huis warm te houden.
  - Daarnaast gaan hun energiekosten er ook nog eens van omlaag.
  opties:
  - {fileID: 4168637598212588060}
