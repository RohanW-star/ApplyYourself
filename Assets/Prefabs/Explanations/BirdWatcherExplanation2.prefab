  m_Script: {fileID: 11500000, guid: 7ed69b4369b61f54a8fa52440f19a322, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialoogSysteem
  dialogueText: {fileID: 2543958636162741558}
  typingSpeed: 0.01
  sentences:
  - 'Ik raad aan om meer vogelhuisjes te plaatsen, u kunt dit in uw tuin doen, of
    we kunnen naar de gemeente toestappen om dit voor de hele buurt te doen. '
  - 'Vogelhuisjes dienen als veilige plekken voor vogels om hun nesten te bouwen. '
  - Hierdoor hebben de jongen ook meer kans om te overleven totdat ze zelf het nest
    uit kunnen.
  opties:
  - {fileID: 3303962908735904140}
